# ElevenLabs Voice API (optional - game works without it)
# Sign up at https://elevenlabs.io for free tier (10k chars/month)
NEXT_PUBLIC_ELEVENLABS_API_KEY=your_api_key_here

# Voice ID for Old Man Buck (grumpy old man)
# Default: "Adam" (pNInz6obpgDQGcFmaJgB) - deep authoritative voice
# Other good options:
#   "Bill" (pqHfZKP75CvOlQylNhV4) - older American male
#   "George" (JBFqnCBsd6RMkjVDRZzb) - warm older male
NEXT_PUBLIC_ELEVENLABS_VOICE_ID=pqHfZKP75CvOlQylNhV4

# App URL (set in Railway)
NEXT_PUBLIC_URL=http://localhost:3000
